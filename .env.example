# ─── Banco de dados PostgreSQL ───────────────────────────────────────────────
# Servidor PostgreSQL externo — NÃO use DATABASE_URL (conexão é dinâmica por tenant)
# No Railway: configure estas variáveis nas Environment Variables do serviço
PG_HOST=cloud.digitalrf.com.br
PG_PORT=5433
PG_USER=seu_usuario_app
PG_PASSWORD=sua_senha_app

# ─── Autenticação JWT ─────────────────────────────────────────────────────────
# Gerar com: openssl rand -hex 64
JWT_SECRET=segredo_jwt_muito_longo_e_aleatorio_aqui
JWT_EXPIRES_IN=8h

# ─── Anthropic IA ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── E-mail (Resend) — recuperação de senha ──────────────────────────────────
# Chave da conta Resend (mesma conta/dominio pode ser reaproveitada do digitalrf-help)
RESEND_API_KEY=re_...
# Remetente e reply-to — trocar de dominio depois e so mudar aqui, sem tocar no codigo
EMAIL_FROM="VitaRF <noreply@digitalrf.com.br>"
EMAIL_REPLY_TO=suporte@digitalrf.com.br

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://financeiro.digitalrf.com.br
# NODE_ENV e PORT são definidos automaticamente pelo Railway em produção

# ─── Uploads (anexos de prontuário) ──────────────────────────────────────────
# Caminho do volume persistente no Railway. Em dev local, aponte para uma pasta
# qualquer da máquina (ex: ./uploads-dev).
UPLOADS_DIR=/data/uploads

# ─── Desenvolvimento apenas (não definir em produção) ────────────────────────
# DEV_NO_AUTH=true
# DEV_DB_NAME=nome_do_banco_dev
# DEV_EMPRESA_ID=1
